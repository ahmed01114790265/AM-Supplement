@using AM_Supplement.Contracts.DTO.AdminDasboard.AdminAccount
@model LoginDTO
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Terminal | Login";
}

<div class="auth-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-4 col-lg-5 col-md-7">

                <div class="login-card-glass">
                    <div class="auth-header text-center">
                        <div class="brand-logo-container mb-3">
                            <i class="bi bi-lightning-charge-fill text-warning"></i>
                        </div>
                        <h2 class="auth-title">ADMIN <span class="text-warning">LOGIN</span></h2>
                        <p class="auth-subtitle">Authorized Personnel Only</p>
                    </div>

                    <div class="auth-body">
                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()

                            <div class="input-block mb-4">
                                <label asp-for="Email" class="dash-label">Administrative Email</label>
                                <div class="input-icon-wrapper">
                                    <i class="bi bi-envelope-at icon-prefix"></i>
                                    <input asp-for="Email" class="form-control-dash" placeholder="admin@amsupplement.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger-glow"></span>
                            </div>

                            <div class="input-block mb-3">
                                <label asp-for="Password" class="dash-label">Access Key</label>
                                <div class="input-icon-wrapper">
                                    <i class="bi bi-shield-lock icon-prefix"></i>
                                    <input asp-for="Password" type="password" class="form-control-dash" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger-glow"></span>
                            </div>

                            <div class="mb-4 d-flex justify-content-between align-items-center">
                                <div class="form-check custom-check">
                                    <input asp-for="RememberMe" class="form-check-input" />
                                    <label asp-for="RememberMe" class="form-check-label text-white-50">Stay Authenticated</label>
                                </div>
                            </div>

                            <button type="submit" class="btn-login-gold">
                                <span>INITIALIZE SESSION</span>
                                <i class="bi bi-box-arrow-in-right ms-2"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <div class="auth-footer mt-4 text-center">
                    <p class="text-white-50 small">
                        <i class="bi bi-info-circle me-1"></i>
                        IP Address is logged for security auditing.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* 1. Background Settings */
    body {
        background: #08090a; /* لون داكن جداً ليعطي عمق */
        color: #fff;
    }

    /* 2. Glass Card Design */
    .login-card-glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        padding: 50px 40px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    }

    /* 3. Logo & Typography */
    .brand-logo-container {
        font-size: 3rem;
        filter: drop-shadow(0 0 15px rgba(255, 204, 0, 0.4));
    }

    .auth-title {
        font-family: 'Teko', sans-serif;
        font-size: 2.2rem;
        letter-spacing: 3px;
        font-weight: 800;
        margin-bottom: 5px;
    }

    .auth-subtitle {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 700;
    }

    /* 4. Form Inputs */
    .dash-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #ffcc00;
        margin-bottom: 8px;
        display: block;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .icon-prefix {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.3);
        font-size: 1.1rem;
    }

    .form-control-dash {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 15px !important;
        color: #fff !important;
        padding: 14px 15px 14px 45px !important;
        transition: all 0.3s ease;
    }

        .form-control-dash:focus {
            background: rgba(255, 255, 255, 0.08) !important;
            border-color: #ffcc00 !important;
            box-shadow: 0 0 20px rgba(255, 204, 0, 0.15) !important;
            outline: none;
        }

    /* 5. Custom Checkbox */
    .custom-check .form-check-input {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }

        .custom-check .form-check-input:checked {
            background-color: #ffcc00;
            border-color: #ffcc00;
        }

    /* 6. Login Button */
    .btn-login-gold {
        background: #ffcc00;
        color: #000;
        border: none;
        width: 100%;
        padding: 16px;
        border-radius: 15px;
        font-weight: 900;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .btn-login-gold:hover {
            background: #fff;
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(255, 204, 0, 0.3);
        }

    /* 7. Validation Messages */
    .text-danger-glow {
        color: #ff4d4d;
        font-size: 0.7rem;
        font-weight: 700;
        margin-top: 5px;
        display: block;
        text-shadow: 0 0 10px rgba(255, 77, 77, 0.3);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}