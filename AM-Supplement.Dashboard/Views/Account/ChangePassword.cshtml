@using AM_Supplement.Contracts.DTO.AdminDasboard.AdminAccount
@model ChangePasswordDTO
@{
    Layout = "_Layout";
    ViewData["Title"] = "Security Settings";
}

<div class="dashboard-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8">

            <div class="auth-card-glass">
                <div class="card-header-modern">
                    <div class="icon-box-gold">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h3 class="mt-3">Security Control</h3>
                    <p class="text-muted-gold">Update your administrative credentials</p>
                </div>

                <div class="card-body-modern">
                    <form asp-action="ChangePassword" method="post" class="needs-validation">
                        @Html.AntiForgeryToken()

                        <div class="input-group-modern mb-4">
                            <label asp-for="CurrentPassword"><i class="bi bi-key me-2"></i>Old Password</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control-dash" placeholder="••••••••" />
                            <span asp-validation-for="CurrentPassword" class="text-danger-glow"></span>
                        </div>

                        <div class="input-group-modern mb-4">
                            <label asp-for="NewPassword"><i class="bi bi-lock me-2"></i>New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control-dash" placeholder="Min. 8 characters" />
                            <span asp-validation-for="NewPassword" class="text-danger-glow"></span>
                        </div>

                        <div class="input-group-modern mb-5">
                            <label asp-for="ConfirmNewPassword"><i class="bi bi-check2-circle me-2"></i>Confirm New Password</label>
                            <input asp-for="ConfirmNewPassword" type="password" class="form-control-dash" placeholder="Repeat new password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger-glow"></span>
                        </div>

                        <button type="submit" class="btn-dash-primary">
                            <span>UPDATE SECURITY KEY</span>
                            <i class="bi bi-arrow-right-short ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="security-footer mt-4 text-center">
                <p><i class="bi bi-info-circle me-2"></i> Password should be complex for maximum security.</p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Dashboard Theme Background */
    body {
        background-color: #0a0b0c;
        color: #e2e8f0;
    }

    /* Glassmorphism Card */
    .auth-card-glass {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
    }

    /* Header & Icon */
    .card-header-modern {
        text-align: center;
        margin-bottom: 30px;
    }

    .icon-box-gold {
        width: 60px;
        height: 60px;
        background: rgba(255, 204, 0, 0.1);
        border: 1px solid #ffcc00;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 1.8rem;
        color: #ffcc00;
        box-shadow: 0 0 20px rgba(255, 204, 0, 0.2);
    }

    .text-muted-gold {
        color: #a0aec0;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    /* Modern Inputs */
    .input-group-modern label {
        display: block;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #ffcc00;
        margin-bottom: 8px;
        letter-spacing: 1.5px;
    }

    .form-control-dash {
        background: rgba(255, 255, 255, 0.03) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 12px !important;
        color: white !important;
        padding: 12px 15px !important;
        transition: 0.3s;
    }

        .form-control-dash:focus {
            background: rgba(255, 255, 255, 0.07) !important;
            border-color: #ffcc00 !important;
            box-shadow: 0 0 15px rgba(255, 204, 0, 0.1) !important;
            outline: none;
        }

    /* Primary Action Button */
    .btn-dash-primary {
        background: #ffcc00;
        color: #000;
        border: none;
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .btn-dash-primary:hover {
            background: #fff;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255, 204, 0, 0.2);
        }

    /* Error Messages */
    .text-danger-glow {
        color: #ff4d4d;
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    .security-footer p {
        color: #718096;
        font-size: 0.8rem;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}