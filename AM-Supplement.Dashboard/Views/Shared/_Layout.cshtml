<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - AM Admin Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;600;700&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --sidebar-width: 280px;
            --accent-gold: #ffcc00;
            --bg-dark: #08090a;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        body {
            background-color: var(--bg-dark);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            margin: 0;
        }

            /* Ambient Background Effect */
            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: radial-gradient(circle at 20% 30%, rgba(255, 204, 0, 0.05) 0%, transparent 40%), radial-gradient(circle at 80% 70%, rgba(13, 110, 253, 0.05) 0%, transparent 40%);
                z-index: -1;
            }

        /* Sidebar Glassmorphism */
        aside {
            width: var(--sidebar-width);
            min-height: 100vh;
            position: fixed;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--glass-border);
            z-index: 1000;
            padding: 2rem 1.5rem;
        }

        .brand-section {
            padding-bottom: 3rem;
        }

        .brand-logo {
            font-family: 'Teko', sans-serif;
            font-size: 2rem;
            letter-spacing: 2px;
            color: #fff;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        /* Nav Links Styling */
        .nav-link {
            border-radius: 12px;
            padding: 12px 18px;
            color: rgba(255, 255, 255, 0.5) !important;
            font-weight: 500;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            border: 1px solid transparent;
        }

            .nav-link i {
                font-size: 1.3rem;
                margin-right: 15px;
                transition: 0.3s;
            }

            .nav-link:hover {
                background: rgba(255, 255, 255, 0.05);
                color: var(--accent-gold) !important;
                border-color: rgba(255, 204, 0, 0.1);
                transform: translateX(5px);
            }

            .nav-link.active {
                background: linear-gradient(90deg, rgba(255, 204, 0, 0.15) 0%, transparent 100%);
                color: var(--accent-gold) !important;
                border-left: 3px solid var(--accent-gold);
                font-weight: 700;
            }

                .nav-link.active i {
                    color: var(--accent-gold);
                    filter: drop-shadow(0 0 5px rgba(255, 204, 0, 0.5));
                }

        /* Content Area Wrapper */
        main {
            margin-left: var(--sidebar-width);
            padding: 2rem 3rem;
            min-height: 100vh;
        }

        /* Logout Section */
        .logout-wrapper {
            margin-top: auto;
            padding-top: 2rem;
        }

        .btn-logout {
            background: rgba(255, 77, 77, 0.05);
            border: 1px solid rgba(255, 77, 77, 0.2);
            color: #ff4d4d;
            border-radius: 10px;
            padding: 10px;
            transition: 0.3s;
            width: 100%;
        }

            .btn-logout:hover {
                background: #ff4d4d;
                color: #fff;
                box-shadow: 0 0 15px rgba(255, 77, 77, 0.3);
            }

        /* Utility Classes */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            aside {
                transform: translateX(-100%);
            }

            main {
                margin-left: 0;
                padding: 1.5rem;
            }

            aside.show {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body>

    <div class="d-flex">
        <aside class="d-flex flex-column shadow-lg">
            <div class="brand-section">
                <a href="/" class="brand-logo">
                    <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                    <span>AM <span class="text-warning">ADMIN</span></span>
                </a>
            </div>

            <nav class="flex-column nav nav-pills gap-1">
                @{
                    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                }

                <a class="nav-link @(currentAction == "Index" || currentAction == "Dashboard" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Overview</span>
                </a>

                <a class="nav-link @(currentAction == "Products" || currentAction == "EditProduct" || currentAction == "CreateProduct" ? "active" : "")"
                   asp-controller="Admin" asp-action="Products">
                    <i class="bi bi-stack"></i>
                    <span>Inventory</span>
                </a>

                <a class="nav-link @(currentAction == "Orders" || currentAction == "OrderDetails" ? "active" : "")"
                   asp-controller="Admin" asp-action="Orders">
                    <i class="bi bi-shield-shaded"></i>
                    <span>Operations</span>
                </a>

                <a class="nav-link @(currentAction == "Archive" ? "active" : "")"
                   asp-controller="Admin" asp-action="Archive">
                    <i class="bi bi-archive-fill"></i>
                    <span>System Archive</span>
                </a>
            </nav>
            <div class="logout-wrapper">
                <hr class="opacity-10 mb-4">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-logout d-flex align-items-center justify-content-center">
                        <i class="bi bi-power me-2"></i> <span>System Sign-out</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="flex-fill">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>