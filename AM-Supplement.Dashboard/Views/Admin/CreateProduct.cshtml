@using AM_Supplement.Shared.Enums
@model CreateProductViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Supplement";
}

<div class="dashboard-root py-5" style="background-color: #000; min-height: 100vh;">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-5 pb-3 border-bottom border-secondary">
            <div>
                <h2 style="font-family: 'Arial Black', sans-serif; font-size: 2.2rem; color: #ffcc00; text-transform: uppercase; margin: 0;">
                    <i class="bi bi-plus-circle-fill me-2"></i> CREATE <span style="color: #fff;">SUPPLEMENT</span>
                </h2>
                <p style="color: #00ff88; font-weight: 900; letter-spacing: 1px; margin-top: 5px;">ADD NEW UNIT TO DIGITAL INVENTORY</p>
            </div>
            <a asp-action="Products" class="btn-solid-back">
                <i class="bi bi-arrow-left"></i> BACK TO INVENTORY
            </a>
        </div>

        <form asp-action="CreateProduct" method="post" enctype="multipart/form-data" class="row g-4">
            @Html.AntiForgeryToken()

            <div class="col-lg-8">
                <div class="form-card-solid p-4 h-100">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-4"></div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Name" class="solid-label">PRODUCT IDENTITY</label>
                            <input asp-for="Name" class="form-control-solid lg" placeholder="e.g. ULTRA WHEY ISOLATE" />
                            <span asp-validation-for="Name" class="validation-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="solid-label">MARKET PRICE ($)</label>
                            <div class="input-group-solid">
                                <span class="unit-prefix">$</span>
                                <input asp-for="Price" class="form-control-solid" type="number" step="0.01" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Price" class="validation-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Stock" class="solid-label">INVENTORY COUNT</label>
                            <div class="input-group-solid">
                                <span class="unit-prefix"><i class="bi bi-box-seam"></i></span>
                                <input asp-for="Stock" class="form-control-solid" type="number" placeholder="Total Units" />
                            </div>
                            <span asp-validation-for="Stock" class="validation-error"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="solid-label">PRODUCT STORY & BENEFITS</label>
                            <textarea asp-for="Description" rows="5" class="form-control-solid" placeholder="Describe the formula..."></textarea>
                            <span asp-validation-for="Description" class="validation-error"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Taste" class="solid-label">FLAVOR PROFILE</label>
                            <input asp-for="Taste" class="form-control-solid" placeholder="e.g. Vanilla" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Weight" class="solid-label">NET WEIGHT (G)</label>
                            <div class="input-group-solid">
                                <input asp-for="Weight" class="form-control-solid" type="number" />
                                <span class="unit-suffix">GRAMS</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DiscountPercentage" class="solid-label">PROMO DISCOUNT %</label>
                            <div class="input-group-solid promo">
                                <input asp-for="DiscountPercentage" class="form-control-solid" type="number" />
                                <span class="unit-suffix">% OFF</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Type" class="solid-label">PRODUCT CATEGORY</label>
                            <select asp-for="Type" class="form-select-solid" asp-items="Html.GetEnumSelectList<ProductType>()">
                                <option value="">-- SELECT CLASSIFICATION --</option>
                            </select>
                            <span asp-validation-for="Type" class="validation-error"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="form-card-solid p-4 mb-4 text-center">
                    <label class="solid-label mb-3 d-block">PRODUCT VISUAL ASSET</label>
                    <div class="image-preview-box">
                        <img id="preview"
                             src="/assets/products/default-product.png"
                             onerror="this.onerror=null; this.src='https://via.placeholder.com/150?text=No+Image+Found';" />
                    </div>

                    <input asp-for="Image" type="file" class="d-none" id="fileInput"
                           accept="image/*" onchange="previewImage(this)" />

                    <button type="button" class="btn-solid-upload w-100" onclick="document.getElementById('fileInput').click()">
                        <i class="bi bi-camera-fill me-2"></i> SELECT IMAGE
                    </button>
                </div>

                <div class="form-card-solid p-4">
                    <button type="submit" class="btn-publish-solid w-100 mb-3">
                        <i class="bi bi-cloud-arrow-up-fill me-2"></i> PUBLISH PRODUCT
                    </button>
                    <a asp-action="Products" class="btn-discard-solid w-100">
                        DISCARD DRAFT
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* 1. Containers & Cards */
    .form-card-solid {
        background-color: #111;
        border: 2px solid #222;
        border-radius: 15px;
    }

    /* 2. Typography & Labels */
    .solid-label {
        color: #ffcc00;
        font-weight: 900;
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        margin-bottom: 8px;
        display: block;
    }

    /* 3. Inputs - High Contrast */
    .form-control-solid, .form-select-solid {
        background-color: #000 !important;
        border: 2px solid #333 !important;
        color: #fff !important;
        padding: 12px 15px !important;
        border-radius: 8px !important;
        font-weight: 600;
    }

        .form-control-solid:focus {
            border-color: #ffcc00 !important;
            outline: none;
        }

        .form-control-solid.lg {
            font-size: 1.3rem;
            font-weight: 900;
            color: #ffcc00 !important;
        }

    /* 4. Input Groups */
    .input-group-solid {
        display: flex;
        align-items: center;
        background: #000;
        border-radius: 8px;
    }

    .unit-prefix, .unit-suffix {
        padding: 0 15px;
        font-weight: 900;
        color: #555;
    }

    .promo .unit-suffix {
        color: #ff4d4d;
    }

    /* 5. Image Preview */
    .image-preview-box {
        background: #000;
        border: 2px solid #333;
        height: 250px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        overflow: hidden;
    }

        .image-preview-box img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

    /* 6. Buttons */
    .btn-solid-back {
        background: #222;
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 900;
    }

    .btn-solid-upload {
        background: #333;
        color: #fff;
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: 800;
    }

    .btn-publish-solid {
        background-color: #00ff88;
        color: #000;
        border: none;
        padding: 18px;
        border-radius: 12px;
        font-weight: 900;
        font-size: 1.1rem;
    }

    .btn-discard-solid {
        background: transparent;
        color: #ff4d4d;
        border: none;
        display: block;
        text-align: center;
        text-decoration: none;
        font-weight: 800;
    }

    .validation-error {
        color: #ff4d4d;
        font-size: 0.75rem;
        font-weight: 900;
        margin-top: 5px;
        display: block;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}