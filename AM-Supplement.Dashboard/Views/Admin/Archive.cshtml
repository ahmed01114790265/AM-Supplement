@using AM_Supplement.Contracts.DTO
@model List<ProductDTO>

<div class="admin-vault-final p-4">
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="main-stat-box">
                <span class="label">TOTAL ITEMS IN VAULT</span>
                <span class="big-number">@(Model?.Count ?? 0)</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="main-stat-box">
                <span class="label">TOTAL UNITS AT RISK</span>
                <span class="big-number text-warning">@(Model?.Sum(p => p.Stock) ?? 0)</span>
            </div>
        </div>
    </div>

    <div class="data-table-container">
        <table class="table table-dark table-striped align-middle m-0">
            <thead class="table-light text-dark">
                <tr>
                    <th class="ps-4">PRODUCT DESCRIPTION</th>
                    <th class="text-center">PRICE ($)</th>
                    <th class="text-center">STOCK (QTY)</th>
                    <th class="text-end pe-4">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var p in Model)
                    {
                        <tr class="admin-row">
                            <td class="ps-4 fw-bold text-white">
                                @p.Name
                            </td>
                            <td class="text-center">
                                <span class="admin-numeric-price">@p.Price.ToString("F2")</span>
                            </td>
                            <td class="text-center">
                                <span class="admin-numeric-stock">@p.Stock</span>
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="Restore" asp-route-id="@p.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-success btn-sm fw-bold">RESTORE</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* ألوان صلبة لضمان الوضوح التام */
    .admin-vault-final {
        background-color: #000; /* خلفية سوداء تماماً */
        color: #fff;
    }

    .main-stat-box {
        background: #1a1a1a;
        padding: 20px;
        border: 2px solid #333;
        border-radius: 10px;
        text-align: center;
    }

        .main-stat-box .label {
            display: block;
            color: #888;
            font-size: 0.8rem;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .main-stat-box .big-number {
            font-size: 3rem;
            font-weight: 900;
            line-height: 1;
        }

    /* تنسيق الأرقام داخل الجدول */
    .admin-numeric-price {
        color: #00ff00 !important; /* أخضر نيون */
        font-size: 1.5rem;
        font-weight: 800;
        font-family: Arial, sans-serif;
    }

    .admin-numeric-stock {
        color: #ffffff !important; /* أبيض ناصع */
        font-size: 1.5rem;
        font-weight: 800;
        background: #333;
        padding: 2px 10px;
        border-radius: 5px;
    }

    .data-table-container {
        border: 2px solid #333;
        border-radius: 10px;
        overflow: hidden;
    }

    .admin-row:hover {
        background-color: #222 !important;
    }

    .table-light th {
        font-weight: 900;
        letter-spacing: 1px;
    }
</style>