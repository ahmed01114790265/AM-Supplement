@using AM_Supplement.Shared.Enums
@model EditProductViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Update Product";
}

<div class="dashboard-container py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between mb-5">
            <div>
                <h2 class="dash-title"><i class="bi bi-pencil-square text-warning me-2"></i> EDIT <span class="text-warning">PRODUCT</span></h2>
                <p class="text-muted-gold mb-0">Modifying details for: <strong class="text-white">@Model.Name</strong></p>
            </div>
            <a asp-action="Products" class="btn-dash-outline">
                <i class="bi bi-arrow-left"></i> <span>Back to Inventory</span>
            </a>
        </div>

        <form asp-action="EditProduct" method="post" enctype="multipart/form-data" class="row g-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CurrentImage" />

            <div class="col-lg-8">
                <div class="card-glass-modern p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger-glass mb-4 small"></div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Name" class="dash-label">Product Designation</label>
                            <input asp-for="Name" class="form-control-dash lg" />
                            <span asp-validation-for="Name" class="text-danger-glow"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="dash-label">Current Price ($)</label>
                            <div class="input-group-dash">
                                <span class="prefix text-warning">$</span>
                                <input asp-for="Price" class="form-control-dash" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger-glow"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Stock" class="dash-label">Inventory Level</label>
                            <div class="input-group-dash">
                                <span class="prefix"><i class="bi bi-box-seam"></i></span>
                                <input asp-for="Stock" class="form-control-dash" type="number" />
                            </div>
                            <span asp-validation-for="Stock" class="text-danger-glow"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="dash-label">Full Specification</label>
                            <textarea asp-for="Description" rows="6" class="form-control-dash"></textarea>
                            <span asp-validation-for="Description" class="text-danger-glow"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Taste" class="dash-label">Flavor Variant</label>
                            <input asp-for="Taste" class="form-control-dash" />
                            <span asp-validation-for="Taste" class="text-danger-glow"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Weight" class="dash-label">Weight (Grams)</label>
                            <div class="input-group-dash">
                                <input asp-for="Weight" class="form-control-dash" type="number" />
                                <span class="suffix text-white-50">g</span>
                            </div>
                            <span asp-validation-for="Weight" class="text-danger-glow"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="DiscountPercentage" class="dash-label">Active Discount</label>
                            <div class="input-group-dash highlight">
                                <input asp-for="DiscountPercentage" class="form-control-dash" type="number" />
                                <span class="suffix">% OFF</span>
                            </div>
                            <span asp-validation-for="DiscountPercentage" class="text-danger-glow"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Type" class="dash-label">Product Category</label>
                            <select asp-for="Type" class="form-select-dash" asp-items="Html.GetEnumSelectList<ProductType>()">
                                <option value="">-- Change Category --</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger-glow"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card-glass-modern p-4 mb-4 text-center">
                    <label class="dash-label mb-3 d-block">Visual Asset</label>

                    <div class="image-preview-studio mb-3 border-warning">
                        <img id="imagePreview"
                             src="/assets/products/@(string.IsNullOrEmpty(Model.CurrentImage) ? "default-product.png" : Model.CurrentImage)"
                             class="img-fluid rounded-4"
                             onerror="this.src='/assets/products/default-product.png';" />

                        <div class="preview-overlay bg-warning text-dark">
                            <i class="bi bi-pencil-fill"></i>
                        </div>
                    </div>

                    <div class="upload-section">
                        <label asp-for="NewImage" class="dash-label small opacity-75">Upload New Image</label>
                        <input asp-for="NewImage" type="file" class="form-control-dash sm mt-2"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="previewImage(this)" />
                        <div class="form-text text-white-50 mt-2 small">
                            <i class="bi bi-info-circle text-warning"></i> Keep empty to retain current photo.
                        </div>
                    </div>
                </div>

                <div class="card-glass-modern p-4">
                    <button type="submit" class="btn-update-neon w-100 mb-3">
                        <i class="bi bi-check-circle-fill me-2"></i> COMMIT CHANGES
                    </button>
                    <a asp-action="Products" class="btn-cancel w-100">
                        Cancel & Discard
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* 1. Dashboard Theme */
    body {
        background-color: #08090a;
        color: #fff;
    }

    .dash-title {
        font-family: 'Teko', sans-serif;
        font-size: 2.2rem;
        letter-spacing: 2px;
        font-weight: 800;
    }

    .text-muted-gold {
        color: #a0aec0;
        font-size: 0.9rem;
    }

    /* 2. Glassmorphism Design */
    .card-glass-modern {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    }

    /* 3. Inputs & Labels */
    .dash-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #ffcc00;
        margin-bottom: 8px;
    }

    .form-control-dash, .form-select-dash {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        border-radius: 12px !important;
        color: #fff !important;
        padding: 12px 16px !important;
        transition: 0.3s;
    }

        .form-control-dash.lg {
            font-size: 1.3rem;
            font-weight: 700;
            border-color: rgba(255, 204, 0, 0.3) !important;
        }

        .form-control-dash:focus {
            border-color: #ffcc00 !important;
            box-shadow: 0 0 20px rgba(255, 204, 0, 0.15) !important;
        }

    /* 4. Input Groups */
    .input-group-dash {
        display: flex;
        align-items: center;
    }

        .input-group-dash .prefix, .input-group-dash .suffix {
            padding: 0 12px;
            font-weight: 800;
        }

    /* 5. Studio Preview */
    .image-preview-studio {
        position: relative;
        background: #000;
        border-radius: 20px;
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .preview-overlay {
        position: absolute;
        bottom: 15px;
        right: 15px;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* 6. Action Buttons */
    .btn-update-neon {
        background: #ffcc00;
        color: #000;
        border: none;
        padding: 16px;
        border-radius: 15px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: 0.4s;
    }

        .btn-update-neon:hover {
            background: #fff;
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(255, 204, 0, 0.3);
        }

    .btn-cancel {
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-weight: 700;
        display: block;
        text-align: center;
    }

        .btn-cancel:hover {
            color: #ff4d4d;
        }

    .btn-dash-outline {
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
        padding: 8px 18px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
    }

    .text-danger-glow {
        color: #ff4d4d;
        font-size: 0.75rem;
        font-weight: 700;
        display: block;
        margin-top: 5px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreview').style.opacity = '0';
                    setTimeout(() => {
                        document.getElementById('imagePreview').style.transition = '0.5s';
                        document.getElementById('imagePreview').style.opacity = '1';
                    }, 50);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}