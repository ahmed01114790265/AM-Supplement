@using AMSupplement.Domain.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<style>
    /* 1. Glass nav */
    .navbar-glass-ultra {
        background: rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(15px) saturate(180%);
        -webkit-backdrop-filter: blur(15px) saturate(180%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding: 18px 0;
        transition: all 0.4s ease;
        margin-bottom: 0 !important;
    }

    .navbar.scrolled {
        background: rgba(255, 255, 255, 0.9) !important;
        backdrop-filter: blur(20px);
        padding: 10px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    /* brand */
    .navbar-brand-modern {
        font-weight: 800;
        letter-spacing: 2px;
        font-size: 1.5rem;
        color: #ffffff !important;
        text-shadow: 0 2px 10px rgba(0,0,0,0.3);
        text-decoration: none;
    }
    .navbar.scrolled .navbar-brand-modern { color: #000 !important; }

    /* links */
    .nav-link-modern {
        color: rgba(255, 255, 255, 0.9) !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
        transition: 0.3s;
        text-shadow: 0 1px 5px rgba(0,0,0,0.2);
    }
    .navbar.scrolled .nav-link-modern { color: #333 !important; text-shadow: none; }
    .nav-link-modern:hover { color: #ffcc00 !important; }

    /* whatsapp */
    .whatsapp-pill {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(37, 211, 102, 0.1);
        border: 1px solid rgba(37, 211, 102, 0.4);
        color: #25d366 !important;
        padding: 7px 18px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.75rem;
        text-decoration: none;
        transition: 0.3s;
        backdrop-filter: blur(5px);
    }
    .whatsapp-pill:hover {
        background: #25d366;
        color: #fff !important;
        box-shadow: 0 0 15px rgba(37, 211, 102, 0.4);
        transform: translateY(-2px);
    }

    /* cta */
    .btn-gold-modern {
        background: #ffcc00;
        color: #000 !important;
        font-weight: 800;
        border-radius: 50px;
        padding: 8px 22px;
        text-transform: uppercase;
        font-size: 0.75rem;
        border: none;
        transition: 0.3s;
    }
    .btn-gold-modern:hover {
        background: #fff;
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(255,204,0,0.3);
    }
</style>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top navbar-glass-ultra">
    <div class="container">
        <a class="navbar-brand-modern" asp-controller="Product" asp-action="Index">
            <i class="bi bi-lightning-fill text-warning"></i> AM SUPPLEMENT
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <i class="bi bi-list text-white fs-2"></i>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto">
                <li class="nav-item ms-lg-4"><a class="nav-link-modern nav-link" asp-controller="Product" asp-action="Index">@Localizer["NavShop"]</a></li>
                <li class="nav-item"><a class="nav-link-modern nav-link" asp-controller="Cart" asp-action="Index"><i class="bi bi-cart3"></i> @Localizer["NavCart"]</a></li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item me-lg-3">
                    <a href="https://wa.me/201029067976" class="whatsapp-pill" target="_blank">
                        <i class="bi bi-whatsapp fs-6"></i>
                        <span>@Localizer["Support"]</span>
                    </a>
                </li>

                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item">
                        <span class="nav-link-modern text-white small me-3">
                            @Localizer["Hello"] <strong class="text-warning">@User.Identity!.Name</strong>
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3 fw-bold">@Localizer["Logout"]</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link-modern nav-link" asp-controller="Account" asp-action="LogIn">@Localizer["Login"]</a></li>
                    <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
                        <a class="btn-gold-modern btn text-decoration-none" asp-controller="Account" asp-action="Register">@Localizer["JoinNow"]</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<script>
    window.addEventListener('scroll', function () {
        const nav = document.querySelector('.navbar');
        if (window.scrollY > 50) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
    });
</script>
