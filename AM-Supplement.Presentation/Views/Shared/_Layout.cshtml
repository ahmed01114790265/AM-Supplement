<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AM Supplement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #ffcc00;
            --primary-dark: #f5b700;
            --ink: #0a0c10;
            --panel: rgba(255,255,255,0.04);
            --stroke: rgba(255,255,255,0.08);
            --text-muted: #9aa0b5;
            --transition: all 0.35s ease;
        }

        body {
            background-color: var(--ink);
            background-image:
                radial-gradient(circle at 15% 20%, rgba(255, 204, 0, 0.12), transparent 35%),
                radial-gradient(circle at 80% 10%, rgba(111, 126, 255, 0.09), transparent 30%),
                url('/images/products/38840335-c9a3-4c97-8a5e-e33300db12b6.jpeg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            position: relative;
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #f6f7fb;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background: linear-gradient(145deg, rgba(6, 8, 12, 0.85), rgba(6, 8, 12, 0.9));
            z-index: -1;
        }

        .content-container {
            padding: 120px 0 80px;
            flex: 1 0 auto;
            animation: layoutFadeIn 0.8s ease-out;
        }

        @@keyframes layoutFadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .whatsapp-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: linear-gradient(120deg, #25d366, #22b357);
            color: #fff;
            padding: 12px 22px;
            border-radius: 999px;
            z-index: 9999;
            box-shadow: 0 10px 20px rgba(37, 211, 102, 0.2);
            transition: var(--transition);
            text-decoration: none !important;
            }

            .whatsapp-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 14px 28px rgba(37, 211, 102, 0.25);
            }
    </style>
</head>
<body>
    <header><partial name="_Navbar" /></header>

    <div class="container-fluid p-0">
        <div class="row g-0">
            @if (IsSectionDefined("Sidebar"))
            {
                <aside class="col-lg-2 d-none d-lg-block border-end border-white border-opacity-10 min-vh-100 p-4">
                    <div style="position: sticky; top: 120px;">@RenderSection("Sidebar")</div>
                </aside>
            }
            <main class="@(IsSectionDefined("Sidebar") ? "col-lg-10" : "col-12")">
                <div class="content-container px-3 px-md-5">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <partial name="_Footer" />
    <a href="https://wa.me/201029067976" class="whatsapp-btn"><i class="bi bi-whatsapp me-2"></i>SUPPORT</a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            window.scrollY > 50 ? nav.classList.add('scrolled') : nav.classList.remove('scrolled');
        });
    </script>
    @RenderSection("Scripts", false)
</body>
</html>
