<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AM Supplement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;700&family=Inter:wght@300;400;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-gold: #ffcc00;
            --dark-deep: #0a0b0c;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        body {
            background-color: var(--dark-deep) !important;
            /* The path must match your folder structure */
            background-image: url('/images/products/38840335-c9a3-4c97-8a5e-e33300db12b6.jpeg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed; /* Parallax effect */
            background-repeat: no-repeat;
            position: relative;
        }

            /* Add a dark gradient overlay so text remains readable */
            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: radial-gradient(circle at center, rgba(10, 11, 12, 0.7) 0%, rgba(5, 5, 5, 0.95) 100%);
                z-index: -1; /* Sits behind content */
            }

        /* 🟢 The "Safe Space" Fix */
        .content-container {
            padding-top: 120px !important; /* Prevents content from hiding under Navbar */
            padding-bottom: 80px;
            flex: 1 0 auto;
            animation: layoutFadeIn 0.8s ease-out;
        }

        @@keyframes layoutFadeIn {
            from

        {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .whatsapp-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #25d366;
            color: white;
            padding: 12px 25px;
            border-radius: 50px;
            z-index: 9999;
            box-shadow: 0 10px 20px rgba(37, 211, 102, 0.2);
            transition: var(--transition);
            text-decoration: none !important;
        }

            .whatsapp-btn:hover {
                transform: scale(1.05);
                background: #128c7e;
                color: white;
            }
    </style>
</head>
<body>
    <header><partial name="_Navbar" /></header>

    <div class="container-fluid p-0">
        <div class="row g-0">
            @if (IsSectionDefined("Sidebar"))
            {
                <aside class="col-lg-2 d-none d-lg-block border-end border-white border-opacity-10 min-vh-100 p-4">
                    <div style="position: sticky; top: 120px;">@RenderSection("Sidebar")</div>
                </aside>
            }
            <main class="@(IsSectionDefined("Sidebar") ? "col-lg-10" : "col-12")">
                <div class="content-container px-3 px-md-5">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <partial name="_Footer" />
    <a href="https://wa.me/201029067976" class="whatsapp-btn"><i class="bi bi-whatsapp me-2"></i>SUPPORT</a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            window.scrollY > 50 ? nav.classList.add('scrolled') : nav.classList.remove('scrolled');
        });
    </script>
    @RenderSection("Scripts", false)
</body>
</html>