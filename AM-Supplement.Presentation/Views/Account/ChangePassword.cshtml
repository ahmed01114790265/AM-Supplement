@using AM_Supplement.Presentation.ViewsModel.AccountViewModel
@model ChangePasswordDTO
@{
    ViewData["Title"] = "Settings";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 bg-dark-matte" style="background-color: rgba(20, 22, 24, 0.8); border: 1px solid #2d3135 !important;">
            <div class="card-header bg-transparent border-secondary py-3">
                <h4 class="text-white mb-0 fw-bold"><i class="bi bi-shield-lock me-2 text-warning"></i>Security Settings</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-secondary small fw-bold">Verify Email</label>
                        <input asp-for="Email" class="form-control bg-dark border-secondary text-white shadow-none" readonly />
                    </div>

                    <div class="mb-3 border-top border-secondary pt-3">
                        <label asp-for="CurrentPassword" class="form-label text-secondary small fw-bold">Current Password</label>
                        <input asp-for="CurrentPassword" type="password" class="form-control bg-dark border-secondary text-white shadow-none" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label text-secondary small fw-bold text-warning">New Password</label>
                        <input asp-for="NewPassword" type="password" class="form-control bg-dark border-warning text-white shadow-none" />
                    </div>

                    <button type="submit" class="btn btn-outline-warning w-100 fw-bold py-2">UPDATE PASSWORD</button>
                </form>
            </div>
        </div>
    </div>
</div>