@model CartDTO
@{
    ViewData["Title"] = "Final Checkout";
    var whatsappNumber = "201029067976";

    // تجهيز قائمة المنتجات نصياً لاستخدامها في رسالة الواتساب
    var itemsSummary = "";
    if (Model?.Items != null)
    {
        foreach (var item in Model.Items)
        {
            itemsSummary += $"- {item.Name} (x{item.Quantity})%0A";
        }
    }
}

<div class="container py-5">
    <h2 class="text-warning fw-bold mb-4" style="font-family: 'Teko'; font-size: 3rem;">
        <i class="bi bi-shield-check me-2"></i>COMPLETE YOUR ORDER
    </h2>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card bg-dark-matte border-0 shadow-lg" style="background-color: rgba(20, 22, 24, 0.9); border: 1px solid #2d3135 !important; border-radius: 15px;">
                <div class="table-responsive p-3">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead>
                            <tr class="text-secondary border-bottom border-secondary">
                                <th class="py-3 border-0">PRODUCT</th>
                                <th class="py-3 border-0 text-center">QTY</th>
                                <th class="py-3 border-0 text-end">SUBTOTAL</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="border-bottom border-secondary">
                                    <td class="py-3 fw-bold text-white">@item.Name</td>
                                    <td class="text-center text-secondary">@item.Quantity</td>
                                    <td class="text-end text-warning">@((item.Price * item.Quantity).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-black border-warning shadow-lg" style="border: 2px solid #ffcc00 !important; border-radius: 20px; overflow: hidden;">
                <div class="card-body p-4">
                    <h4 class="text-white mb-4 border-bottom border-secondary pb-2">Order Summary</h4>

                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-secondary fs-5">Total Due:</span>
                        <span class="text-warning fw-bold fs-3">@Model.Total.ToString("C")</span>
                    </div>

                    <div class="mb-4">
                        <label class="text-secondary small fw-bold mb-2">CHOOSE PAYMENT METHOD:</label>
                        <select id="paymentMethod" class="form-select bg-dark border-secondary text-white shadow-none py-3">
                            <option value="cash">💵 Cash on Delivery</option>
                            <option value="vodafone">📱 Vodafone Cash</option>
                        </select>
                    </div>

                    <div id="vodafoneBox" class="p-3 mb-4 rounded-3 d-none animate__animated animate__fadeIn" style="background: rgba(230, 0, 0, 0.1); border: 1px solid #e60000;">
                        <p class="text-danger small fw-bold mb-1"><i class="bi bi-info-circle me-1"></i> Transfer to this number:</p>
                        <h3 class="text-white text-center fw-bold mb-2">01029067976</h3>
                        <p class="text-secondary x-small mb-0 text-center">Please send the transfer receipt on WhatsApp.</p>
                    </div>

                    <form asp-action="Pay" method="post" id="checkoutForm">
                        <button type="submit" id="confirmBtn" class="btn btn-warning btn-lg w-100 py-3 fw-bold">
                            <i class="bi bi-whatsapp me-2"></i>CONFIRM & PAY
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const paymentMethod = document.getElementById('paymentMethod');
        const vodafoneBox = document.getElementById('vodafoneBox');
        const confirmBtn = document.getElementById('confirmBtn');

        paymentMethod.addEventListener('change', function() {
            if (this.value === 'vodafone') {
                vodafoneBox.classList.remove('d-none');
                confirmBtn.classList.replace('btn-warning', 'btn-danger');
                confirmBtn.innerHTML = '<i class="bi bi-whatsapp me-2"></i>CONFIRM V-CASH';
            } else {
                vodafoneBox.classList.add('d-none');
                confirmBtn.classList.replace('btn-danger', 'btn-warning');
                confirmBtn.innerHTML = '<i class="bi bi-whatsapp me-2"></i>CONFIRM & PAY';
            }
        });

        document.getElementById('checkoutForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const method = paymentMethod.value;
            const total = "@Model.Total.ToString("C")";
            const items = "@itemsSummary";

            let message = "";
            if(method === 'vodafone') {
                message = `أهلاً AM Supplement%0Aلقد قمت بتحويل مبلغ ${total} عبر فودافون كاش لطلب المنتجات التالية:%0A${items}متى سيصل الطلب؟`;
            } else {
                message = `أهلاً AM Supplement%0Aأريد تأكيد طلب (دفع عند الاستلام) بمبلغ ${total}:%0A${items}شكراً لكم.`;
            }

            // فتح الواتساب في صفحة جديدة
            window.open(`https://wa.me/@whatsappNumber?text=${message}`, '_blank');

            // إرسال النموذج فعلياً للخادم لتسجيل الطلب
            this.submit();
        });
    </script>
}