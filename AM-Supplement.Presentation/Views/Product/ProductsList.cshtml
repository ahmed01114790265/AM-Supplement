@using AM_Supplement.Presentation.Models
@using AM_Supplement.Shared.Enums
@model ProductsListViewModel

<div class="catalog-header mb-5">
    <h1 class="text-white fw-bold display-4 mb-0" style="font-family: 'Teko';">
        <span class="text-warning">AM</span> SUPPLEMENT
    </h1>
    <div class="d-flex align-items-center gap-2 opacity-50 text-uppercase small tracking-widest">
        <i class="bi bi-geo-alt"></i> Premium Quality Guaranteed
    </div>
</div>

<div class="filter-card p-4 mb-5 border border-white border-opacity-10 rounded-4" style="background: rgba(255,255,255,0.02); backdrop-filter: blur(10px);">
    <form asp-action="GetProductsList" method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="small text-secondary fw-bold text-uppercase mb-2 d-block">Category</label>
            <select name="productTypeFilter" class="form-select bg-dark border-secondary text-white shadow-none">
                <option value="">All Supplements</option>
                @foreach (var type in Enum.GetValues(typeof(ProductType)))
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="small text-secondary fw-bold text-uppercase mb-2 d-block">Sort By</label>
            <select name="sorting" class="form-select bg-dark border-secondary text-white shadow-none">
                <option value="">Newest Gear</option>
                <option value="PriceDesc">Price: High to Low</option>
                <option value="PriceAsc">Price: Low to High</option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-warning w-100 fw-bold py-2">APPLY FILTERS</button>
            <a asp-action="GetProductsList" class="btn btn-outline-secondary px-3"><i class="bi bi-arrow-counterclockwise"></i></a>
        </div>
    </form>
</div>

<div class="row g-4">
    @foreach (var p in Model.Products)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card h-100 bg-transparent border-0 product-hover">
                <div class="position-relative overflow-hidden rounded-4 mb-3 shadow-lg" style="height: 400px;">
<img src="@(string.IsNullOrEmpty(p.ImageUrl) 
             ? "/assets/products/default-product.png" 
             : (p.ImageUrl.StartsWith("http") ? p.ImageUrl : $"/assets/products/{p.ImageUrl}"))" 
     class="w-100 h-100 object-fit-cover transition-all" 
     alt="@p.Name"
     onerror="this.onerror=null; this.src='https://via.placeholder.com/300?text=No+Image+Found';">                    <div class="position-absolute bottom-0 start-0 w-100 p-4 bg-gradient-dark">
                        <a asp-action="GetProduct" asp-route-id="@p.Id" class="btn btn-warning w-100 rounded-pill fw-bold">VIEW DETAILS</a>
                    </div>
                </div>
                <div class="px-2">
                    <small class="text-warning fw-bold">@p.Type</small>
                    <h5 class="text-white fw-bold">@p.Name.ToUpper()</h5>
                    <div class="d-flex align-items-center gap-2">
                        <span class="fs-4 fw-bold text-white">$@p.Price</span>
                        <span class="text-secondary small">/ @p.Weight g</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div> @if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-5 mb-5">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-lg gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link bg-dark border-secondary text-warning rounded-3 shadow-sm"
                           href="@Url.Action("GetProductsList", new { pageNumber = Model.CurrentPage - 1, productTypeFilter = Context.Request.Query["productTypeFilter"], sorting = Context.Request.Query["sorting"] })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == Model.CurrentPage ? "bg-warning text-dark border-warning" : "bg-dark border-secondary text-white") rounded-3 fw-bold shadow-sm"
                           href="@Url.Action("GetProductsList", new { pageNumber = i, productTypeFilter = Context.Request.Query["productTypeFilter"], sorting = Context.Request.Query["sorting"] })">
                            @i
                        </a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link bg-dark border-secondary text-warning rounded-3 shadow-sm"
                           href="@Url.Action("GetProductsList", new { pageNumber = Model.CurrentPage + 1, productTypeFilter = Context.Request.Query["productTypeFilter"], sorting = Context.Request.Query["sorting"] })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}

<style>
    /* تأثير التحويم على الكارت */
    .product-hover {
        transition: transform 0.3s ease;
    }

        .product-hover:hover {
            transform: translateY(-10px);
        }

        .product-hover img {
            transition: transform 0.5s ease;
        }

        .product-hover:hover img {
            transform: scale(1.1);
        }

    /* تدرج خلفية الزر */
    .bg-gradient-dark {
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    }

    /* التنسيق الخاص بالترقيم */
    .pagination .page-link {
        border-width: 2px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        min-width: 50px;
        text-align: center;
    }

        .pagination .page-link:hover {
            background-color: #ffcc00 !important;
            color: #000 !important;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(255, 204, 0, 0.2) !important;
        }

    .pagination .active .page-link {
        box-shadow: 0 0 15px rgba(255, 204, 0, 0.4);
    }
</style>