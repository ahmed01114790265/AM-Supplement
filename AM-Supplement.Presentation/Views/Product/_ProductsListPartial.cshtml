@model List<ProductDTO>
<div class="admin-header d-flex justify-content-between align-items-end mb-5 border-bottom border-white border-opacity-10 pb-4">
    <div>
        <h2 class="text-white fw-bold display-6 mb-0" style="font-family: 'Teko';">COMMAND CENTER</h2>
        <span class="text-secondary text-uppercase small tracking-widest">Inventory Management System</span>
    </div>
    <a asp-action="CreateProduct" class="btn btn-warning px-4 py-2 fw-bold"><i class="bi bi-plus-lg me-2"></i>NEW PRODUCT</a>
</div>

<div class="row g-4">
    @foreach (var p in Model)
    {
        <div class="col-xl-4 col-md-6">
            <div class="card bg-black border border-white border-opacity-10 rounded-4 overflow-hidden h-100 shadow-sm">
                <div class="row g-0">
                    <div class="col-4 bg-dark d-flex align-items-center justify-content-center p-2">
                        <img src="/assets/products/@p.ImageUrl" class="img-fluid rounded" style="max-height: 120px;">
                    </div>
                    <div class="col-8">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge @(p.Stock < 5 ? "bg-danger" : "bg-dark border border-secondary") text-uppercase">@p.Stock units</span>
                                <span class="text-warning fw-bold">$@p.Price</span>
                            </div>
                            <h6 class="text-white text-truncate mb-3">@p.Name</h6>
                            <div class="d-flex gap-2">
                                <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-warning w-100">EDIT</a>
                                <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" class="w-100">
                                    <button class="btn btn-sm btn-outline-danger w-100" onclick="return confirm('Delete item?')">DEL</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>